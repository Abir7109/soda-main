# SODA v2 Environment Variables
# Copy this file to .env (without .example) and fill in your values

# Required: Google AI API Key
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Brave Search API key (for web_search_live tool)
# Get free at: https://brave.com/search/api (2000 searches/month, no credit card)
# If left blank, DuckDuckGo Instant Answer API is used as fallback.
BRAVE_SEARCH_API_KEY=

# Optional: Development settings
# NODE_ENV=development
# PORT=8000
